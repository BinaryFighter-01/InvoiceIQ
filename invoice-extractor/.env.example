# OpenRouter API Configuration
OPENROUTER_API_KEY=your_api_key_here

# Model Configuration
MODEL_NAME=qwen/qwen3.7-plus

# Application Configuration
RENDER_DPI=150
MAX_FILE_SIZE_MB=20

# ══════════════════════════════════════════════════════════════════
# PHASE 1: Caching & Two-Pass Extraction Configuration
# ══════════════════════════════════════════════════════════════════

# Result Caching
CACHE_ENABLED=true
CACHE_DIRECTORY=uploads/.cache
CACHE_MAX_AGE_HOURS=24

# Two-Pass Extraction
# (No additional config needed - controlled via UI toggle)


# ══════════════════════════════════════════════════════════════════
# PHASE 2: Multi-Page PDF Support Configuration
# ══════════════════════════════════════════════════════════════════

# Multi-page PDF processing
MAX_PDF_PAGES=20
